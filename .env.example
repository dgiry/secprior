# ─────────────────────────────────────────────────────────────────────────────
# CyberVeille Pro — Variables d'environnement Vercel
# Copiez ce fichier en .env.local pour le développement local
# Sur Vercel : Dashboard > votre-projet > Settings > Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── NVD API (optionnel mais recommandé) ──────────────────────────────────────
# Sans clé : 5 req/30s | Avec clé : 50 req/30s
# Obtenir une clé : https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ── Resend (emails transactionnels) ──────────────────────────────────────────
# Gratuit : 3 000 emails/mois, 100/jour
# Inscription : https://resend.com
# Clé API : https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Expéditeur Resend (domaine vérifié requis en production)
# En test, utiliser "onboarding@resend.dev" (sandbox Resend, envoie vers votre email vérifié)
RESEND_FROM=CyberVeille Pro <alerts@votredomaine.com>

# ── SendGrid (emails transactionnels alternatif) ──────────────────────────────
# Gratuit : 100 emails/jour
# Inscription : https://sendgrid.com
# Clé API : https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# Expéditeur SendGrid (Single Sender Verification requise)
# Vérifier sur : https://app.sendgrid.com/settings/sender_auth
SENDGRID_FROM=alerts@votredomaine.com
