{
  "version": 2,
  "name": "cyberveille-pro",
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/fetch-feeds", "destination": "/api/fetch-feeds" },
    { "source": "/api/nvd",         "destination": "/api/nvd" },
    { "source": "/api/epss",        "destination": "/api/epss" },
    { "source": "/api/kev",         "destination": "/api/kev" },
    { "source": "/api/send-alert",  "destination": "/api/send-alert" }
  ]
}
