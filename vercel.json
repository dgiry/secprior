{
  "version": 2,
  "name": "cyberveille-pro",
  "buildCommand": null,
  "outputDirectory": ".",
  "functions": {
    "api/*.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; connect-src 'self' api.first.org services.nvd.nist.gov www.cisa.gov api.resend.com api.sendgrid.com hooks.slack.com; img-src 'self' data:; font-src 'self'"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/fetch-feeds", "destination": "/api/fetch-feeds" },
    { "source": "/api/nvd",          "destination": "/api/nvd" },
    { "source": "/api/epss",         "destination": "/api/epss" },
    { "source": "/api/kev",          "destination": "/api/kev" },
    { "source": "/api/send-alert",   "destination": "/api/send-alert" }
  ]
}
