{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    { "path": "/api/scheduled-digest", "schedule": "0 12 * * *" },
    { "path": "/api/scheduled-digest", "schedule": "0 13 * * *" }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/ai-brief",         "destination": "/api/ai-brief" },
    { "source": "/api/briefing-preview", "destination": "/api/briefing-preview" },
    { "source": "/api/feeds",       "destination": "/api/feeds" },
    { "source": "/api/fetch-feeds", "destination": "/api/fetch-feeds" },
    { "source": "/api/ioc",         "destination": "/api/ioc" },
    { "source": "/api/nvd",         "destination": "/api/nvd" },
    { "source": "/api/epss",        "destination": "/api/epss" },
    { "source": "/api/kev",         "destination": "/api/kev" },
    { "source": "/api/send-alert",        "destination": "/api/send-alert" },
    { "source": "/api/scheduled-digest", "destination": "/api/scheduled-digest" },
    { "source": "/api/status",           "destination": "/api/status" },
    { "source": "/api/tv1-sync",         "destination": "/api/tv1-sync" }
  ]
}
